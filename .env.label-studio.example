# PostgreSQL Configuration (shared with main app)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=insurance_verification
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_SSL=false

# Label Studio Configuration
LABEL_STUDIO_USERNAME=admin@example.com
LABEL_STUDIO_PASSWORD=changeme123
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=

# After first startup, generate an API key in Label Studio:
# 1. Login to http://localhost:8080
# 2. Go to Account & Settings
# 3. Generate API token
# 4. Copy the token to LABEL_STUDIO_API_KEY above
