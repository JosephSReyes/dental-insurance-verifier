# =============================================================================
# LLM API Keys
# =============================================================================
# Set USE_PAID_MODELS=true and fill these in to use cloud LLMs.
# Leave USE_PAID_MODELS=false to use local Ollama models only.
USE_PAID_MODELS=false

OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LangSmith tracing (optional, for observability)
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=insurance-verification

# =============================================================================
# Ollama (local LLM inference)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SERVICE_URL=http://localhost:11434

# General-purpose text model (non-vision tasks)
OLLAMA_MODEL=your-preferred-text-model

# Vision-capable model (required for browser-use agents that read screenshots)
OLLAMA_MODEL_CHAT=your-preferred-vision-model

# =============================================================================
# Dental Office Portal Credentials
# Configure one block per office. Add OFFICE_C_, OFFICE_D_, etc. as needed.
# =============================================================================

# Office A
OFFICE_A_NAME=Your Practice Name
OFFICE_A_ALIASES=alias1,alias2
OFFICE_A_DELTA_DENTAL_USER=your_delta_dental_username
OFFICE_A_DELTA_DENTAL_PASSWORD=your_delta_dental_password
OFFICE_A_DELTA_DENTAL_CONTRACTED_PLANS=PPO,Premier
OFFICE_A_BLUE_CROSS_BLUE_SHIELD_USER=your_bcbs_username
OFFICE_A_BLUE_CROSS_BLUE_SHIELD_PASSWORD=your_bcbs_password
OFFICE_A_BLUE_CROSS_BLUE_SHIELD_CONTRACTED_PLANS=PPO

# Office B (example second office, remove if not needed)
OFFICE_B_NAME=Second Practice Name
OFFICE_B_ALIASES=alias1,alias2
OFFICE_B_DELTA_DENTAL_USER=your_delta_dental_username
OFFICE_B_DELTA_DENTAL_PASSWORD=your_delta_dental_password
OFFICE_B_DELTA_DENTAL_CONTRACTED_PLANS=PPO,Premier
OFFICE_B_BLUE_CROSS_BLUE_SHIELD_USER=your_bcbs_username
OFFICE_B_BLUE_CROSS_BLUE_SHIELD_PASSWORD=your_bcbs_password
OFFICE_B_BLUE_CROSS_BLUE_SHIELD_CONTRACTED_PLANS=PPO,Premier

# =============================================================================
# Portal URLs (update if carriers change login endpoints)
# =============================================================================
DELTA_DENTAL_PORTAL_URL=https://www1.deltadentalins.com/
DELTA_DENTAL_LOGIN_URL=https://www.deltadentalins.com/ciam/login
BLUE_CROSS_BLUE_SHIELD_LOGIN_URL=https://www.dnoaconnect.com/#!/

# =============================================================================
# Database (PostgreSQL + pgvector)
# Matches docker-compose.yml defaults, change if using external DB
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=insurance_verification
POSTGRES_URL=postgresql://postgres:your-postgres-password@localhost:5433/insurance_verification

# =============================================================================
# Label Studio (generated after first login at http://localhost:8081)
# =============================================================================
LABEL_STUDIO_URL=http://localhost:8081
LABEL_STUDIO_API_KEY=your-label-studio-api-key
LABEL_STUDIO_USERNAME=admin@example.com
LABEL_STUDIO_PASSWORD=changeme123

# =============================================================================
# Browser / MCP settings
# =============================================================================
BROWSER_HEADLESS=false
USE_BROWSER_USE=true
BROWSER_USE_SERVICE_URL=http://localhost:8000
CHROME_DEBUG_PORT=9222
MCP_SERVER_PORT=3002

# =============================================================================
# Verification pipeline settings
# =============================================================================
VERIFICATION_FORMS_DIR=verification_forms
VERIFICATION_MAX_RETRIES=3
VERIFICATION_API_TIMEOUT=30
ALLOW_STANDARD_VERIFICATION=true
ALLOW_QUICK_VERIFICATION=true
USE_TEST_VERIFICATION=false

# Infrastructure ports (must match docker-compose.yml)
REDIS_PORT=6380
DOCKER_CONTAINER=false
