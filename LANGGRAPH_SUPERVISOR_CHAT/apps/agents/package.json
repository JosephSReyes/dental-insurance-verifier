{
  "name": "agents",
  "author": "Your Name",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--expose-gc --max-old-space-size=8192\" npx @langchain/langgraph-cli dev --port 2024 --config ../../langgraph.json",
    "build": "turbo build:internal --filter=agents",
    "build:internal": "pnpm run clean && tsc",
    "clean": "rm -rf ./dist .turbo || true",
    "format": "prettier --config .prettierrc --write \"src\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "db:init": "npx tsx scripts/init-database.ts",
    "db:test": "npx tsx scripts/test-rag.ts",
    "db:reset": "npx tsx scripts/reset-database.ts",
    "db:verify": "npx tsx scripts/verify-pgvector.ts",
    "db:show": "npx tsx scripts/show-rag-data.ts",
    "feedback:import": "npx tsx scripts/import-feedback.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.1",
    "@langchain/anthropic": "^0.3.15",
    "@langchain/cohere": "^0.3.2",
    "@langchain/community": "^0.3.35",
    "@langchain/core": "^0.3.42",
    "@langchain/langgraph": "^0.2.55",
    "@langchain/langgraph-checkpoint": "^0.0.16",
    "@langchain/mongodb": "^0.1.0",
    "@langchain/ollama": "^0.2.4",
    "@langchain/openai": "^0.4.4",
    "@langchain/pinecone": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@pinecone-database/pinecone": "^5.1.1",
    "axios": "^1.6.7",
    "cheerio": "^1.1.2",
    "dotenv": "^16.4.5",
    "langchain": "^0.3.19",
    "mongodb": "^6.14.2",
    "playwright": "^1.51.0",
    "puppeteer": "^22.6.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@jest/globals": "^29.7.0",
    "@playwright/mcp": "^0.0.37",
    "@types/node": "^20",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "latest",
    "typescript": "^5"
  }
}